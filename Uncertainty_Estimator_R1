def run_uncertainty_example_fixed(
    x_true_fixed,
    out_fixed,
    *,
    nominal_coverage=0.95,
    src_idx=0,
    do_plots=True,
):
    """
    Fixed-orientation uncertainty diagnostics.

    Works for both fixed EEG and fixed MEG because the posterior space is the
    same: one scalar coefficient per source.

    Parameters
    ----------
    x_true_fixed : ndarray, shape (N,T)
    out_fixed : dict
        Output from BMN / BMN_joint for n_orient=1.
        Required keys:
          - "posterior_mean": (N,T)
          - "posterior_cov" : (N,N)

    Returns
    -------
    results : dict
    """
    ue = UncertaintyEstimator()

    x_true_fixed = np.asarray(x_true_fixed, dtype=float)
    posterior_mean_fixed = np.asarray(out_fixed["posterior_mean"], dtype=float)
    posterior_cov_fixed = np.asarray(out_fixed["posterior_cov"], dtype=float)

    if x_true_fixed.ndim != 2:
        raise ValueError(f"x_true_fixed must be (N,T); got {x_true_fixed.shape}")
    if posterior_mean_fixed.shape != x_true_fixed.shape:
        raise ValueError(
            f'out_fixed["posterior_mean"] must be {x_true_fixed.shape}; '
            f"got {posterior_mean_fixed.shape}"
        )

    N_fixed, T_fixed = x_true_fixed.shape
    if posterior_cov_fixed.shape != (N_fixed, N_fixed):
        raise ValueError(
            f'out_fixed["posterior_cov"] must be {(N_fixed, N_fixed)}; '
            f"got {posterior_cov_fixed.shape}"
        )

    posterior_var_fixed = ue.posterior_variance_from_cov(posterior_cov_fixed)

    diag_fixed_point = ue.pointwise_interval_membership(
        x_true=x_true_fixed,
        x_hat=posterior_mean_fixed,
        posterior_var=posterior_var_fixed,
        nominal_coverage=nominal_coverage,
    )

    diag_fixed_agg = ue.aggregated_interval_membership(
        x_true=x_true_fixed,
        x_hat=posterior_mean_fixed,
        posterior_var=posterior_var_fixed,
        nominal_coverage=nominal_coverage,
    )

    curve_fixed_point = ue.calibration_curve_intervals_pointwise(
        x_true=x_true_fixed,
        x_hat=posterior_mean_fixed,
        posterior_var=posterior_var_fixed,
    )

    curve_fixed_agg = ue.calibration_curve_intervals_aggregated(
        x_true=x_true_fixed,
        x_hat=posterior_mean_fixed,
        posterior_var=posterior_var_fixed,
    )

    if do_plots:
        ue.plot_fixed_interval_membership_pointwise(
            x_true=x_true_fixed,
            x_hat=posterior_mean_fixed,
            posterior_var=posterior_var_fixed,
            src_idx=src_idx,
            nominal_coverage=nominal_coverage,
        )

        ue.plot_fixed_interval_membership_aggregated(
            diag_fixed=diag_fixed_agg,
            src_idx=src_idx,
            nominal_coverage=nominal_coverage,
        )

    print("\n================ FIXED ORIENTATION ====================")
    print("x_true_fixed shape              :", x_true_fixed.shape)
    print("posterior_mean_fixed shape      :", posterior_mean_fixed.shape)
    print("posterior_cov_fixed shape       :", posterior_cov_fixed.shape)
    print("posterior_var_fixed shape       :", posterior_var_fixed.shape)
    print("Pointwise empirical coverage    :", diag_fixed_point["empirical_coverage"])
    print("Aggregated empirical coverage   :", diag_fixed_agg["empirical_coverage"])

    return {
        "ue": ue,
        "posterior_var_fixed": posterior_var_fixed,
        "diag_fixed_point": diag_fixed_point,
        "diag_fixed_agg": diag_fixed_agg,
        "curve_fixed_point": curve_fixed_point,
        "curve_fixed_agg": curve_fixed_agg,
    }


