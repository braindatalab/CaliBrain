# =============================================================================
# Direction-wise calibration metrics
# =============================================================================
#
# These metrics are computed separately for each component/direction.
#
# For EEG:
#       component 1, component 2, component 3
#
# For MEG:
#       component 1, component 2
#
# No macro-average and no worst-direction summary are computed here.
# =============================================================================

def directionwise_calibration_metrics(curve: Dict[str, Any]) -> Dict[str, Any]:
    """
    Compute calibration metrics separately for each component/direction.

    Expected input
    --------------
    curve["nominal_coverages"] : shape (M,)
        Nominal coverage grid.

    curve["empirical_coverages_by_component"] : shape (M,K)
        Empirical coverage curves, one column per component.

    Returns
    -------
    metrics : dict
        Direction-wise calibration metrics.
    """
    nominal = np.asarray(curve["nominal_coverages"], dtype=float)
    empirical_by_component = np.asarray(
        curve["empirical_coverages_by_component"],
        dtype=float,
    )

    if empirical_by_component.ndim != 2:
        raise ValueError(
            "curve['empirical_coverages_by_component'] must have shape (M,K)."
        )

    M, K = empirical_by_component.shape

    if nominal.shape[0] != M:
        raise ValueError(
            "Mismatch between nominal coverage grid and empirical coverage curves."
        )

    metrics_by_component = {}

    for k in range(K):
        empirical = empirical_by_component[:, k]
        diff = empirical - nominal

        under = np.maximum(nominal - empirical, 0.0)
        over = np.maximum(empirical - nominal, 0.0)

        metrics_by_component[k] = {
            "max_underconfidence_deviation": float(np.max(under)),
            "max_overconfidence_deviation": float(np.max(over)),
            "mean_absolute_deviation": float(np.mean(np.abs(diff))),
            "mean_signed_deviation": float(np.mean(diff)),
        }

    return {
        "metrics_by_component": metrics_by_component,
        "n_components": int(K),
    }


def print_directionwise_calibration_metrics(
    label: str,
    metrics: Dict[str, Any],
) -> None:
    """
    Print direction-wise calibration metrics in a readable form.
    """
    print(f"\n================ {label} ================")

    for k, vals in metrics["metrics_by_component"].items():
        print(f"\nComponent {k + 1}")
        print("  max_underconfidence_deviation :", vals["max_underconfidence_deviation"])
        print("  max_overconfidence_deviation  :", vals["max_overconfidence_deviation"])
        print("  mean_absolute_deviation       :", vals["mean_absolute_deviation"])
        print("  mean_signed_deviation         :", vals["mean_signed_deviation"])


