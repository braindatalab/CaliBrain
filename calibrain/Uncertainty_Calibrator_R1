import logging
from typing import Optional, Dict, Any, List, Tuple, Union
from collections import defaultdict

import numpy as np
from scipy.stats import norm, chi2
from sklearn.isotonic import IsotonicRegression


class RunwiseUncertaintyCalibrator:
    """
    External run-wise uncertainty calibrator.

    Purpose
    -------
    This class performs uncertainty recalibration at the level of completed
    simulation/inversion runs. It is designed for the new external-training calibration phase.

    Main idea
    ---------
    For a chosen setting (fixed, eeg_free, meg_free) and mode
    (pointwise, aggregated), the calibrator uses stored run outputs and
    computes empirical coverage curves on a nominal coverage grid. From the
    training runs, it fits a monotone anchored isotonic map

        empirical_coverage = g(nominal_coverage),

    then numerically inverts this map to obtain recalibrated nominal levels

        nominal_recalibrated = g^{-1}(nominal_target).

    On evaluation runs, the class reports:
    - pre-calibration empirical coverage curves,
    - post-calibration empirical coverage curves,
    - pre/post calibration metrics.

    

    Dependency roles
    ----------------
    - UncertaintyEstimator:
        Preferred component for empirical coverage computation if your current
        class exposes a compatible method. If not, this class uses its own
        fallback implementation that is kept consistent with the remembered
        pipeline conventions.
    - MetricEvaluator:
        Preferred component for computing the 4 calibration metrics if your
        current class exposes a compatible method. Otherwise metrics are
        computed internally.

    Supported settings
    ------------------
    - fixed
    - eeg_free
    - meg_free

    Supported modes
    ---------------
    - pointwise
    - aggregated

    Expected run payload
    --------------------
    Each run is typically a dict containing at least:
      fixed:
        x_true            : (N, T)
        posterior_mean    : (N, T) or synonym
        posterior_cov     : (N, N)  or posterior_var : (N,)

      eeg_free:
        x_true            : (N, 3, T)
        posterior_mean    : (N, 3, T) or (3N, T)
        posterior_cov     : (3N, 3N)

      meg_free:
        x_true            : (N, 3, T) physical truth
        posterior_mean    : (N, 2, T) or (2N, T)
        posterior_cov     : (2N, 2N)
        V_tan / Q_basis   : (N, 3, 2) tangent basis

    Optional metadata fields:
        alpha_SNR, subject_id, estimator_name, nnz, etc.

    Notes
    -----
    - For MEG free orientation, truth is treated in physical 3D and projected
      into the local tangent coordinates by V_tan (or Q_basis).
    - For aggregated mode, covariance/variance is scaled by 1/T.
    """

    def __init__(
        self,
        uncertainty_estimator: Optional[Any] = None,
        metric_evaluator: Optional[Any] = None,
        nominal_grid: Optional[np.ndarray] = None,
        repair_psd_blocks: bool = True,
        psd_eig_floor: float = 1e-12,
        inverse_grid_size: int = 4001,
        logger: Optional[logging.Logger] = None,
    ):
        self.uncertainty_estimator = uncertainty_estimator
        self.metric_evaluator = metric_evaluator
        self.nominal_grid = (
            np.asarray(nominal_grid, dtype=float)
            if nominal_grid is not None
            else np.linspace(0.05, 0.99, 20)
        )
        self.nominal_grid = np.clip(self.nominal_grid, 1e-6, 1 - 1e-6)
        self.repair_psd_blocks = bool(repair_psd_blocks)
        self.psd_eig_floor = float(psd_eig_floor)
        self.inverse_grid_size = int(inverse_grid_size)
        self.logger = logger if logger is not None else logging.getLogger(__name__)

        self.models_: Dict[str, Dict[str, Any]] = {}

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------
    def fit(
        self,
        training_runs: List[Dict[str, Any]],
        setting: str,
        mode: str,
        calibration_id: str = "default",
    ) -> Dict[str, Any]:
        """
        Fit inverse-isotonic recalibration from training runs.

        Parameters
        ----------
        training_runs : list of dict
            Stored completed runs used for calibration training.
        setting : str
            One of {"fixed", "eeg_free", "meg_free"}.
        mode : str
            One of {"pointwise", "aggregated"}.
        calibration_id : str
            Identifier under which the fitted recalibration model is stored.

        Returns
        -------
        model_info : dict
            Summary of the fitted calibration model.
        """
        self._validate_setting_mode(setting, mode)

        if len(training_runs) == 0:
            raise ValueError("training_runs is empty.")

        train_run_curves = []
        for i, run in enumerate(training_runs):
            curve = self._compute_run_empirical_curve(
                run=run,
                setting=setting,
                mode=mode,
                nominal_grid=self.nominal_grid,
            )
            train_run_curves.append(curve)

        train_run_curves = np.asarray(train_run_curves, dtype=float)
        empirical_mean_train = np.mean(train_run_curves, axis=0)

        # anchored isotonic fit: empirical = g(nominal)
        x_fit = np.concatenate([[0.0], self.nominal_grid, [1.0]])
        y_fit = np.concatenate([[0.0], empirical_mean_train, [1.0]])
        y_fit = np.clip(y_fit, 0.0, 1.0)

        iso = IsotonicRegression(increasing=True, out_of_bounds="clip")
        iso.fit(x_fit, y_fit)

        # dense forward curve for stable numerical inversion
        dense_nominal = np.linspace(0.0, 1.0, self.inverse_grid_size)
        dense_empirical = iso.predict(dense_nominal)
        dense_empirical = np.maximum.accumulate(np.clip(dense_empirical, 0.0, 1.0))

        inv_empirical, inv_nominal = self._collapse_monotone_for_inverse(
            x=dense_nominal,
            y=dense_empirical,
        )

        recalibrated_nominal_grid = np.interp(
            self.nominal_grid,
            inv_empirical,
            inv_nominal,
            left=0.0,
            right=1.0,
        )
        recalibrated_nominal_grid = np.clip(recalibrated_nominal_grid, 1e-6, 1 - 1e-6)

        model_info = {
            "calibration_id": calibration_id,
            "setting": setting,
            "mode": mode,
            "nominal_grid": self.nominal_grid.copy(),
            "train_run_curves": train_run_curves,
            "train_mean_curve_pre": empirical_mean_train.copy(),
            "isotonic_model": iso,
            "dense_nominal": dense_nominal,
            "dense_empirical": dense_empirical,
            "recalibrated_nominal_grid": recalibrated_nominal_grid,
            "train_metrics_pre": self._compute_calibration_metrics(
                nominal=self.nominal_grid,
                empirical=empirical_mean_train,
            ),
        }

        # optional training post-curve for sanity
        train_run_curves_post = []
        for run in training_runs:
            curve_post = self._compute_run_empirical_curve(
                run=run,
                setting=setting,
                mode=mode,
                nominal_grid=recalibrated_nominal_grid,
            )
            train_run_curves_post.append(curve_post)

        train_run_curves_post = np.asarray(train_run_curves_post, dtype=float)
        train_mean_curve_post = np.mean(train_run_curves_post, axis=0)

        model_info["train_run_curves_post"] = train_run_curves_post
        model_info["train_mean_curve_post"] = train_mean_curve_post
        model_info["train_metrics_post"] = self._compute_calibration_metrics(
            nominal=self.nominal_grid,
            empirical=train_mean_curve_post,
        )

        self.models_[calibration_id] = model_info
        return model_info

    def evaluate(
        self,
        evaluation_runs: List[Dict[str, Any]],
        setting: str,
        mode: str,
        calibration_id: str = "default",
        groupby: Optional[str] = None,
    ) -> Dict[str, Any]:
        """
        Evaluate pre/post calibration on evaluation runs.

        Parameters
        ----------
        evaluation_runs : list of dict
            Stored completed runs used for evaluation.
        setting : str
            One of {"fixed", "eeg_free", "meg_free"}.
        mode : str
            One of {"pointwise", "aggregated"}.
        calibration_id : str
            Fitted calibration model to use.
        groupby : str or None
            Optional metadata key for grouped evaluation, e.g. "alpha_SNR"
            or "subject_id".

        Returns
        -------
        results : dict
            Pre/post calibration curves and metrics.
        """
        self._validate_setting_mode(setting, mode)

        if calibration_id not in self.models_:
            raise ValueError(f"Unknown calibration_id='{calibration_id}'. Fit first.")

        model = self.models_[calibration_id]
        if model["setting"] != setting or model["mode"] != mode:
            raise ValueError(
                f"Stored model '{calibration_id}' was fit for "
                f"setting={model['setting']}, mode={model['mode']} "
                f"but evaluate() received setting={setting}, mode={mode}."
            )

        if len(evaluation_runs) == 0:
            raise ValueError("evaluation_runs is empty.")

        if groupby is None:
            return self._evaluate_group(
                runs=evaluation_runs,
                setting=setting,
                mode=mode,
                model=model,
                group_name="all",
            )

        grouped = defaultdict(list)
        for run in evaluation_runs:
            g = self._extract_group_value(run, groupby)
            grouped[g].append(run)

        out = {}
        for group_name, runs_g in grouped.items():
            out[group_name] = self._evaluate_group(
                runs=runs_g,
                setting=setting,
                mode=mode,
                model=model,
                group_name=str(group_name),
            )

        return {
            "groupby": groupby,
            "groups": out,
        }

    def fit_and_evaluate(
        self,
        training_runs: List[Dict[str, Any]],
        evaluation_runs: List[Dict[str, Any]],
        setting: str,
        mode: str,
        calibration_id: str = "default",
        groupby: Optional[str] = None,
    ) -> Dict[str, Any]:
        """
        Convenience wrapper: fit on training runs, then evaluate on evaluation runs.
        """
        fit_info = self.fit(
            training_runs=training_runs,
            setting=setting,
            mode=mode,
            calibration_id=calibration_id,
        )
        eval_info = self.evaluate(
            evaluation_runs=evaluation_runs,
            setting=setting,
            mode=mode,
            calibration_id=calibration_id,
            groupby=groupby,
        )
        return {
            "fit": fit_info,
            "evaluation": eval_info,
        }

    def recalibrate_nominal_levels(
        self,
        nominal_levels: Union[np.ndarray, List[float]],
        calibration_id: str = "default",
    ) -> np.ndarray:
        """
        Apply learned inverse-isotonic recalibration to arbitrary nominal levels.
        """
        if calibration_id not in self.models_:
            raise ValueError(f"Unknown calibration_id='{calibration_id}'. Fit first.")

        model = self.models_[calibration_id]
        nominal_levels = np.asarray(nominal_levels, dtype=float)
        nominal_levels = np.clip(nominal_levels, 0.0, 1.0)

        dense_nominal = model["dense_nominal"]
        dense_empirical = model["dense_empirical"]
        inv_empirical, inv_nominal = self._collapse_monotone_for_inverse(
            x=dense_nominal,
            y=dense_empirical,
        )

        recal = np.interp(
            nominal_levels,
            inv_empirical,
            inv_nominal,
            left=0.0,
            right=1.0,
        )
        return np.clip(recal, 1e-6, 1 - 1e-6)

    # ------------------------------------------------------------------
    # Group evaluation
    # ------------------------------------------------------------------
    def _evaluate_group(
        self,
        runs: List[Dict[str, Any]],
        setting: str,
        mode: str,
        model: Dict[str, Any],
        group_name: str,
    ) -> Dict[str, Any]:
        nominal_grid = model["nominal_grid"]
        recal_grid = model["recalibrated_nominal_grid"]

        pre_curves = []
        post_curves = []

        for run in runs:
            curve_pre = self._compute_run_empirical_curve(
                run=run,
                setting=setting,
                mode=mode,
                nominal_grid=nominal_grid,
            )
            curve_post = self._compute_run_empirical_curve(
                run=run,
                setting=setting,
                mode=mode,
                nominal_grid=recal_grid,
            )
            pre_curves.append(curve_pre)
            post_curves.append(curve_post)

        pre_curves = np.asarray(pre_curves, dtype=float)
        post_curves = np.asarray(post_curves, dtype=float)

        mean_pre = np.mean(pre_curves, axis=0)
        mean_post = np.mean(post_curves, axis=0)

        return {
            "group_name": group_name,
            "n_runs": len(runs),
            "nominal_grid": nominal_grid.copy(),
            "recalibrated_nominal_grid": recal_grid.copy(),
            "run_curves_pre": pre_curves,
            "run_curves_post": post_curves,
            "mean_curve_pre": mean_pre,
            "mean_curve_post": mean_post,
            "metrics_pre": self._compute_calibration_metrics(
                nominal=nominal_grid,
                empirical=mean_pre,
            ),
            "metrics_post": self._compute_calibration_metrics(
                nominal=nominal_grid,
                empirical=mean_post,
            ),
        }

    # ------------------------------------------------------------------
    # Core run-wise empirical coverage computation
    # ------------------------------------------------------------------
    def _compute_run_empirical_curve(
        self,
        run: Dict[str, Any],
        setting: str,
        mode: str,
        nominal_grid: np.ndarray,
    ) -> np.ndarray:
        """
        Compute one run's empirical coverage curve.

        Preferred path:
            try UncertaintyEstimator adapter
        Fallback path:
            use internal geometry-consistent implementation.
        """
        curve = self._try_uncertainty_estimator_bridge(
            run=run,
            setting=setting,
            mode=mode,
            nominal_grid=nominal_grid,
        )
        if curve is not None:
            return np.asarray(curve, dtype=float)

        return self._compute_run_empirical_curve_fallback(
            run=run,
            setting=setting,
            mode=mode,
            nominal_grid=nominal_grid,
        )

    def _try_uncertainty_estimator_bridge(
        self,
        run: Dict[str, Any],
        setting: str,
        mode: str,
        nominal_grid: np.ndarray,
    ) -> Optional[np.ndarray]:
        """
        Try a few conservative adapter signatures for an external
        UncertaintyEstimator. If no compatible method exists, return None.
        """
        ue = self.uncertainty_estimator
        if ue is None:
            return None

        candidate_methods = [
            "compute_empirical_coverage_curve",
            "estimate_empirical_coverage_curve",
            "evaluate_empirical_coverage_curve",
            "coverage_curve",
        ]

        for method_name in candidate_methods:
            if hasattr(ue, method_name):
                method = getattr(ue, method_name)
                try:
                    curve = method(
                        x_true=run.get("x_true"),
                        posterior_mean=self._get_posterior_mean(run),
                        posterior_cov=self._get_posterior_cov(run),
                        setting=setting,
                        mode=mode,
                        nominal_coverages=nominal_grid,
                        V_tan=self._get_V_tan(run),
                        Q_basis=self._get_Q_basis(run),
                    )
                    return np.asarray(curve, dtype=float)
                except TypeError:
                    pass
                except Exception as e:
                    self.logger.debug(
                        f"UncertaintyEstimator bridge '{method_name}' failed: {e}"
                    )

        return None

    def _compute_run_empirical_curve_fallback(
        self,
        run: Dict[str, Any],
        setting: str,
        mode: str,
        nominal_grid: np.ndarray,
    ) -> np.ndarray:
        if setting == "fixed":
            return self._curve_fixed(run, mode, nominal_grid)

        if setting == "eeg_free":
            return self._curve_eeg_free(run, mode, nominal_grid)

        if setting == "meg_free":
            return self._curve_meg_free(run, mode, nominal_grid)

        raise ValueError(f"Unsupported setting='{setting}'")

    # ------------------------------------------------------------------
    # Fixed orientation
    # ------------------------------------------------------------------
    def _curve_fixed(
        self,
        run: Dict[str, Any],
        mode: str,
        nominal_grid: np.ndarray,
    ) -> np.ndarray:
        x_true = np.asarray(run["x_true"], dtype=float)
        x_hat = self._as_fixed_mean(run)
        posterior_var = self._get_fixed_variance(run)

        if x_true.shape != x_hat.shape:
            raise ValueError(
                f"fixed: shape mismatch x_true{x_true.shape} vs posterior_mean{x_hat.shape}"
            )

        N, T = x_true.shape
        curve = []

        if mode == "pointwise":
            sigma = np.sqrt(np.maximum(posterior_var, 0.0))[:, None]  # (N,1)
            for c in nominal_grid:
                z = norm.ppf(0.5 + 0.5 * c)
                inside = np.abs(x_true - x_hat) <= z * sigma
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        if mode == "aggregated":
            x_true_mean = np.mean(x_true, axis=1)      # (N,)
            x_hat_mean = np.mean(x_hat, axis=1)        # (N,)
            var_mean = posterior_var / float(T)        # static covariance scaled by 1/T
            sigma_mean = np.sqrt(np.maximum(var_mean, 0.0))
            for c in nominal_grid:
                z = norm.ppf(0.5 + 0.5 * c)
                inside = np.abs(x_true_mean - x_hat_mean) <= z * sigma_mean
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        raise ValueError(f"Unsupported mode='{mode}'")

    # ------------------------------------------------------------------
    # EEG free orientation
    # ------------------------------------------------------------------
    def _curve_eeg_free(
        self,
        run: Dict[str, Any],
        mode: str,
        nominal_grid: np.ndarray,
    ) -> np.ndarray:
        x_true = np.asarray(run["x_true"], dtype=float)  # (N,3,T)
        x_hat = self._as_eeg_free_mean(run)              # (N,3,T)
        posterior_cov = self._get_posterior_cov(run)

        if x_true.shape != x_hat.shape:
            raise ValueError(
                f"eeg_free: shape mismatch x_true{x_true.shape} vs posterior_mean{x_hat.shape}"
            )

        N, K, T = x_true.shape
        if K != 3:
            raise ValueError(f"eeg_free expects x_true with shape (N,3,T). Got {x_true.shape}")

        Sigma3 = self._extract_cov_blocks(posterior_cov, n_sources=N, k=3)
        if self.repair_psd_blocks:
            Sigma3 = np.asarray([self._repair_psd(S) for S in Sigma3])

        curve = []

        if mode == "pointwise":
            diffs = x_true - x_hat  # (N,3,T)
            for c in nominal_grid:
                thr = chi2.ppf(c, df=3)
                inside_list = []
                for i in range(N):
                    Sinv = np.linalg.pinv(Sigma3[i])
                    d = diffs[i].T  # (T,3)
                    q = np.einsum("ti,ij,tj->t", d, Sinv, d)
                    inside_list.append(q <= thr)
                inside = np.concatenate(inside_list, axis=0)
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        if mode == "aggregated":
            x_true_mean = np.mean(x_true, axis=2)  # (N,3)
            x_hat_mean = np.mean(x_hat, axis=2)    # (N,3)
            Sigma3_mean = Sigma3 / float(T)

            for c in nominal_grid:
                thr = chi2.ppf(c, df=3)
                inside = []
                for i in range(N):
                    Sinv = np.linalg.pinv(Sigma3_mean[i])
                    d = x_true_mean[i] - x_hat_mean[i]
                    q = float(d.T @ Sinv @ d)
                    inside.append(q <= thr)
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        raise ValueError(f"Unsupported mode='{mode}'")

    # ------------------------------------------------------------------
    # MEG reduced free orientation
    # ------------------------------------------------------------------
    def _curve_meg_free(
        self,
        run: Dict[str, Any],
        mode: str,
        nominal_grid: np.ndarray,
    ) -> np.ndarray:
        x_true_3d = np.asarray(run["x_true"], dtype=float)   # (N,3,T)
        x_hat_2d = self._as_meg_free_mean(run)               # (N,2,T)
        posterior_cov = self._get_posterior_cov(run)
        V_tan = self._get_V_tan(run)                         # (N,3,2)

        if x_true_3d.ndim != 3 or x_true_3d.shape[1] != 3:
            raise ValueError(
                f"meg_free expects x_true physical 3D with shape (N,3,T). Got {x_true_3d.shape}"
            )

        N, _, T = x_true_3d.shape
        if x_hat_2d.shape != (N, 2, T):
            raise ValueError(
                f"meg_free expects posterior_mean shape (N,2,T). Got {x_hat_2d.shape}"
            )
        if V_tan.shape != (N, 3, 2):
            raise ValueError(
                f"meg_free expects V_tan/Q_basis shape (N,3,2). Got {V_tan.shape}"
            )

        Sigma2 = self._extract_cov_blocks(posterior_cov, n_sources=N, k=2)
        if self.repair_psd_blocks:
            Sigma2 = np.asarray([self._repair_psd(S) for S in Sigma2])

        # project physical 3D truth into local tangent coordinates
        # a_true[i,:,t] = V_tan[i].T @ x_true_3d[i,:,t]
        a_true = np.einsum("nik,nit->nkt", V_tan, x_true_3d)  # (N,2,T)

        curve = []

        if mode == "pointwise":
            diffs = a_true - x_hat_2d
            for c in nominal_grid:
                thr = chi2.ppf(c, df=2)
                inside_list = []
                for i in range(N):
                    Sinv = np.linalg.pinv(Sigma2[i])
                    d = diffs[i].T  # (T,2)
                    q = np.einsum("ti,ij,tj->t", d, Sinv, d)
                    inside_list.append(q <= thr)
                inside = np.concatenate(inside_list, axis=0)
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        if mode == "aggregated":
            a_true_mean = np.mean(a_true, axis=2)    # (N,2)
            x_hat_mean = np.mean(x_hat_2d, axis=2)   # (N,2)
            Sigma2_mean = Sigma2 / float(T)

            for c in nominal_grid:
                thr = chi2.ppf(c, df=2)
                inside = []
                for i in range(N):
                    Sinv = np.linalg.pinv(Sigma2_mean[i])
                    d = a_true_mean[i] - x_hat_mean[i]
                    q = float(d.T @ Sinv @ d)
                    inside.append(q <= thr)
                curve.append(np.mean(inside))
            return np.asarray(curve, dtype=float)

        raise ValueError(f"Unsupported mode='{mode}'")

    # ------------------------------------------------------------------
    # Metric computation
    # ------------------------------------------------------------------
    def _compute_calibration_metrics(
        self,
        nominal: np.ndarray,
        empirical: np.ndarray,
    ) -> Dict[str, float]:
        """
        Preferred path:
            try MetricEvaluator
        Fallback path:
            compute internally.

        Convention used here:
            diff = empirical - nominal

        Then:
            underconfidence deviation = max(diff, 0)
            overconfidence deviation  = max(-diff, 0)
        """
        me = self.metric_evaluator
        if me is not None:
            candidate_methods = [
                "evaluate_calibration_metrics",
                "compute_calibration_metrics",
                "calibration_metrics",
            ]
            for method_name in candidate_methods:
                if hasattr(me, method_name):
                    method = getattr(me, method_name)
                    try:
                        out = method(nominal=nominal, empirical=empirical)
                        if isinstance(out, dict):
                            return out
                    except TypeError:
                        pass
                    except Exception as e:
                        self.logger.debug(
                            f"MetricEvaluator bridge '{method_name}' failed: {e}"
                        )

        nominal = np.asarray(nominal, dtype=float)
        empirical = np.asarray(empirical, dtype=float)
        diff = empirical - nominal

        return {
            "max_underconfidence_deviation": float(np.max(np.maximum(diff, 0.0))),
            "max_overconfidence_deviation": float(np.max(np.maximum(-diff, 0.0))),
            "mean_absolute_deviation": float(np.mean(np.abs(diff))),
            "mean_signed_deviation": float(np.mean(diff)),
        }

    # ------------------------------------------------------------------
    # Run field extraction helpers
    # ------------------------------------------------------------------
    def _get_posterior_mean(self, run: Dict[str, Any]) -> np.ndarray:
        for key in ["posterior_mean", "x_hat", "mu_post", "posterior_mean_reshaped"]:
            if key in run and run[key] is not None:
                return np.asarray(run[key], dtype=float)
        raise KeyError("Run is missing posterior mean. Expected one of: "
                       "'posterior_mean', 'x_hat', 'mu_post', 'posterior_mean_reshaped'.")

    def _get_posterior_cov(self, run: Dict[str, Any]) -> np.ndarray:
        for key in ["posterior_cov", "Sigma_post", "cov_post"]:
            if key in run and run[key] is not None:
                return np.asarray(run[key], dtype=float)
        raise KeyError("Run is missing posterior covariance. Expected one of: "
                       "'posterior_cov', 'Sigma_post', 'cov_post'.")

    def _get_Q_basis(self, run: Dict[str, Any]) -> Optional[np.ndarray]:
        return None if "Q_basis" not in run else np.asarray(run["Q_basis"], dtype=float)

    def _get_V_tan(self, run: Dict[str, Any]) -> np.ndarray:
        if "V_tan" in run and run["V_tan"] is not None:
            return np.asarray(run["V_tan"], dtype=float)
        if "Q_basis" in run and run["Q_basis"] is not None:
            return np.asarray(run["Q_basis"], dtype=float)
        raise KeyError("Run is missing 'V_tan' or 'Q_basis' for meg_free.")

    def _get_fixed_variance(self, run: Dict[str, Any]) -> np.ndarray:
        if "posterior_var" in run and run["posterior_var"] is not None:
            v = np.asarray(run["posterior_var"], dtype=float)
            if v.ndim != 1:
                raise ValueError(f"posterior_var must be 1D. Got shape {v.shape}")
            return v

        cov = self._get_posterior_cov(run)
        if cov.ndim != 2 or cov.shape[0] != cov.shape[1]:
            raise ValueError(f"posterior_cov must be square. Got {cov.shape}")
        return np.diag(cov).copy()

    def _as_fixed_mean(self, run: Dict[str, Any]) -> np.ndarray:
        x_hat = self._get_posterior_mean(run)
        if x_hat.ndim != 2:
            raise ValueError(f"fixed posterior_mean must have shape (N,T). Got {x_hat.shape}")
        return x_hat

    def _as_eeg_free_mean(self, run: Dict[str, Any]) -> np.ndarray:
        x_hat = self._get_posterior_mean(run)
        x_true = np.asarray(run["x_true"], dtype=float)
        if x_true.ndim != 3 or x_true.shape[1] != 3:
            raise ValueError(f"eeg_free x_true must have shape (N,3,T). Got {x_true.shape}")

        N, _, T = x_true.shape

        if x_hat.ndim == 3:
            if x_hat.shape != (N, 3, T):
                raise ValueError(
                    f"eeg_free posterior_mean has wrong shape. "
                    f"Expected {(N,3,T)}, got {x_hat.shape}"
                )
            return x_hat

        if x_hat.ndim == 2:
            if x_hat.shape != (3 * N, T):
                raise ValueError(
                    f"eeg_free flattened posterior_mean expected shape {(3*N,T)}, "
                    f"got {x_hat.shape}"
                )
            return x_hat.reshape(N, 3, T)

        raise ValueError(f"Unsupported eeg_free posterior_mean shape {x_hat.shape}")

    def _as_meg_free_mean(self, run: Dict[str, Any]) -> np.ndarray:
        x_hat = self._get_posterior_mean(run)
        x_true = np.asarray(run["x_true"], dtype=float)
        if x_true.ndim != 3 or x_true.shape[1] != 3:
            raise ValueError(f"meg_free x_true must have shape (N,3,T). Got {x_true.shape}")

        N, _, T = x_true.shape

        if x_hat.ndim == 3:
            if x_hat.shape != (N, 2, T):
                raise ValueError(
                    f"meg_free posterior_mean has wrong shape. "
                    f"Expected {(N,2,T)}, got {x_hat.shape}"
                )
            return x_hat

        if x_hat.ndim == 2:
            if x_hat.shape != (2 * N, T):
                raise ValueError(
                    f"meg_free flattened posterior_mean expected shape {(2*N,T)}, "
                    f"got {x_hat.shape}"
                )
            return x_hat.reshape(N, 2, T)

        raise ValueError(f"Unsupported meg_free posterior_mean shape {x_hat.shape}")

    # ------------------------------------------------------------------
    # Covariance helpers
    # ------------------------------------------------------------------
    def _extract_cov_blocks(self, cov: np.ndarray, n_sources: int, k: int) -> np.ndarray:
        cov = np.asarray(cov, dtype=float)
        expected = k * n_sources
        if cov.shape != (expected, expected):
            raise ValueError(
                f"Expected posterior_cov shape {(expected, expected)} for k={k}, "
                f"n_sources={n_sources}, got {cov.shape}"
            )

        blocks = []
        for i in range(n_sources):
            sl = slice(k * i, k * (i + 1))
            blocks.append(cov[sl, sl])
        return np.asarray(blocks, dtype=float)

    def _repair_psd(self, S: np.ndarray) -> np.ndarray:
        S = 0.5 * (S + S.T)
        eigvals, eigvecs = np.linalg.eigh(S)
        eigvals = np.maximum(eigvals, self.psd_eig_floor)
        return eigvecs @ np.diag(eigvals) @ eigvecs.T

    # ------------------------------------------------------------------
    # Inverse isotonic helpers
    # ------------------------------------------------------------------
    def _collapse_monotone_for_inverse(
        self,
        x: np.ndarray,
        y: np.ndarray,
        tol: float = 1e-12,
    ) -> Tuple[np.ndarray, np.ndarray]:
        """
        Convert monotone y(x) into a strictly usable inverse table.

        Returns
        -------
        y_unique, x_representative
        """
        x = np.asarray(x, dtype=float)
        y = np.asarray(y, dtype=float)
        if x.ndim != 1 or y.ndim != 1 or len(x) != len(y):
            raise ValueError("x and y must be 1D arrays of equal length.")

        y = np.maximum.accumulate(y)

        y_unique = [y[0]]
        x_rep = [x[0]]

        for i in range(1, len(y)):
            if abs(y[i] - y_unique[-1]) > tol:
                y_unique.append(y[i])
                x_rep.append(x[i])
            else:
                x_rep[-1] = x[i]

        y_unique = np.asarray(y_unique, dtype=float)
        x_rep = np.asarray(x_rep, dtype=float)

        if y_unique[0] > 0.0:
            y_unique = np.concatenate([[0.0], y_unique])
            x_rep = np.concatenate([[0.0], x_rep])

        if y_unique[-1] < 1.0:
            y_unique = np.concatenate([y_unique, [1.0]])
            x_rep = np.concatenate([x_rep, [1.0]])

        return y_unique, x_rep

    # ------------------------------------------------------------------
    # Group/metadata helpers
    # ------------------------------------------------------------------
    def _extract_group_value(self, run: Dict[str, Any], key: str) -> Any:
        if key in run:
            return run[key]
        if "meta" in run and isinstance(run["meta"], dict) and key in run["meta"]:
            return run["meta"][key]
        return "unknown"

