import logging
from typing import Optional, Tuple

import numpy as np
from mne.io.constants import FIFF


# =============================================================================
# Sensor simulator
# =============================================================================
class SensorSimulator:
    """
    Simulates synthetic sensor-level measurements from source-level activity.

    This class performs two steps:
      (1) Forward projection (clean signal): y_clean = L * x
      (2) Additive Gaussian white noise with controlled SNR level:
          y_noisy = y_clean + eta * eps, where eps ~ N(0, sigma^2 I)

    Supported orientation conventions
    -------------------------------
    Fixed orientation:
      - x: (n_sources, n_times)              [nAm]
      - L: (n_sensors, n_sources)            [sensor_unit / nAm]
      - y: (n_sensors, n_times)              [sensor_unit]

    Free orientation:
      - x: (n_sources, 3, n_times)           [nAm]  (3 components of dipole moment)
      - L: (n_sensors, n_sources, 3)         [sensor_unit / nAm]
      - y: (n_sensors, n_times)              [sensor_unit]

    Units
    -----
    By default, metadata assumes MEG magnetometers:
      - kind    = FIFFV_MEG_CH
      - units   = FIFF_UNIT_T
      - unitmult= FIFF_UNITM_F  (femto; 1e-15)
    These are metadata fields; numerical outputs depend on your L units.
    """

    def __init__(self, logger: Optional[logging.Logger] = None):
        """
        Parameters
        ----------
        logger : logging.Logger, optional
            Logger instance. If None, uses module logger.
        """
        self.logger = logger if logger else logging.getLogger(__name__)

        # Default metadata (MEG magnetometers unless overwritten elsewhere)
        self.kind: int = FIFF.FIFFV_MEG_CH
        self.units: int = FIFF.FIFF_UNIT_T
        self.unitmult: int = FIFF.FIFF_UNITM_F
        self.coil_type: Optional[int] = None

    def __getstate__(self):
        state = self.__dict__.copy()
        state["logger"] = None
        return state

    def __setstate__(self, state):
        self.__dict__.update(state)
        if self.logger is None:
            self.logger = logging.getLogger(self.__class__.__name__)

    def set_sensor_metadata(
        self,
        *,
        kind: Optional[int] = None,
        units: Optional[int] = None,
        unitmult: Optional[int] = None,
        coil_type: Optional[int] = None,
    ) -> None:
        """Update sensor metadata (FIFF kind/unit/multiplier) atomically."""
        if kind is not None:
            self.kind = kind # 1 for FIFFV_MEG_CH, 2 for FIFFV_EEG_CH
        if units is not None:
            self.units = units
        if unitmult is not None:
            self.unitmult = unitmult
        if coil_type is not None:
            self.coil_type = coil_type
    
    def _project_sources_to_sensors(self, x: np.ndarray, L: np.ndarray) -> np.ndarray:
        """
        Project source activity into sensor space using the leadfield.

        Parameters
        ----------
        x : np.ndarray
            Source activity.
            - fixed: (n_sources, n_times)
            - free : (n_sources, 3, n_times)

            Typically measured in nAm for dipole moments.

        L : np.ndarray
            Leadfield mapping sources to sensors.
            - fixed: (n_sensors, n_sources)
            - free : (n_sensors, n_sources, 3)

            Units depend on modality and how L is constructed, e.g.
            - MEG: fT / nAm (or T / nAm with metadata scaling)
            - EEG: µV / nAm

        Returns
        -------
        y_clean : np.ndarray
            Clean sensor signal (noiseless), shape (n_sensors, n_times).

        Notes (math)
        -----------
        Fixed orientation:
            y(t) = L x(t)

        Free orientation:
            y_n(t) = sum_m sum_r L_{n,m,r} * x_{m,r}(t)
            Implemented as: einsum("nmr,mrt->nt", L, x)
        """
        # ---- FIXED ORIENTATION (unchanged numeric path) ----
        # Keeps exactly the same behavior as your draft: return L @ x
        if L.ndim == 2 and x.ndim == 2:
            return L @ x

        # ---- FREE ORIENTATION (added; does not affect fixed numerics) ----
        # Expected: L (n_sensors, n_sources, 3), x (n_sources, 3, n_times)
        if L.ndim == 3 and x.ndim == 3:
            if L.shape[2] != 3 or x.shape[1] != 3:
                raise ValueError(
                    f"Free orientation expects L(...,3) and x(:,3,:); got L{L.shape}, x{x.shape}"
                )
            if L.shape[1] != x.shape[0]:
                raise ValueError(
                    f"Dimension mismatch: L has n_sources={L.shape[1]} but x has n_sources={x.shape[0]}"
                )
            return np.einsum("nmr,mrt->nt", L, x)

        raise ValueError(f"Incompatible shapes for projection: L{L.shape}, x{x.shape}")

    def _add_noise(
        self,
        y_clean: np.ndarray,
        alpha_SNR: float = 0.5,
        sensor_white_noise_std: float = 1.0,
        noise_seed: int = 42,
    ) -> Tuple[np.ndarray, np.ndarray, float]:
        """
        Add homoscedastic (same variance for all sensors) white Gaussian noise
        with a controlled SNR-like mixing parameter alpha_SNR.

        Noise model
        ----------
        eps ~ N(0, sigma^2 I) with sigma = sensor_white_noise_std
        y_noisy = y_clean + eta * eps

        Scaling eta is chosen using Frobenius norms:
            ||y_clean||_F and ||eps||_F

        Interpretation of alpha_SNR
        ---------------------------
        alpha_SNR in [0, 1]:
          - alpha_SNR = 1.0  => y_noisy = y_clean  (no noise)
          - alpha_SNR = 0.0  => y_noisy = eta*eps  (pure noise scaled to match signal norm)
          - otherwise:
              eta = ((1 - alpha_SNR) / alpha_SNR) * (||y_clean||_F / ||eps||_F)

        Parameters
        ----------
        y_clean : np.ndarray
            Clean sensor signal, shape (n_sensors, n_times).
        alpha_SNR : float
            Mixing parameter in [0, 1].
        sensor_white_noise_std : float
            Standard deviation sigma of base Gaussian noise eps.
        noise_seed : int
            Seed for reproducibility of eps.

        Returns
        -------
        y_noisy : np.ndarray
            Noisy sensor signal, shape (n_sensors, n_times).
        eps_scaled : np.ndarray
            Added noise term (eta * eps), shape (n_sensors, n_times).
        eta : float
            Noise scaling factor.
        """
        if not (0.0 <= alpha_SNR <= 1.0):
            raise ValueError("alpha_SNR must be in [0, 1].")

        noise_rng = np.random.RandomState(int(noise_seed))

        if alpha_SNR == 1.0:
            eps = np.zeros_like(y_clean)
            return y_clean.copy(), eps, 0.0

        # Base white Gaussian noise
        eps = noise_rng.normal(loc=0.0, scale=float(sensor_white_noise_std), size=y_clean.shape)

        # Frobenius norms
        signal_norm = np.linalg.norm(y_clean, ord="fro")
        eps_norm = np.linalg.norm(eps, ord="fro")

        # Guard against degenerate eps (e.g., std=0)
        if eps_norm < 1e-12:
            return y_clean.copy(), np.zeros_like(y_clean), 0.0

        if alpha_SNR == 0.0:
            # Pure noise scaled to have the same Frobenius norm as the signal
            eta = signal_norm / eps_norm
            eps_scaled = eta * eps
            return eps_scaled.copy(), eps_scaled, float(eta)

        eta = ((1 - alpha_SNR) / alpha_SNR) * (signal_norm / eps_norm)
        eps_scaled = eta * eps
        y_noisy = y_clean + eps_scaled

        return y_noisy, eps_scaled, float(eta)

    def simulate(
        self,
        x: np.ndarray,
        L: np.ndarray,
        alpha_SNR: float = 0.5,
        sensor_white_noise_std: float = 1.0,
        seed: int = 42,
    ) -> Tuple[np.ndarray, np.ndarray, np.ndarray, float]:
        """
        Simulate sensor data by (1) forward projection and (2) noise addition.

        Parameters
        ----------
        x : np.ndarray
            Source activity:
              - fixed: (n_sources, n_times)
              - free : (n_sources, 3, n_times)
        L : np.ndarray
            Leadfield:
              - fixed: (n_sensors, n_sources)
              - free : (n_sensors, n_sources, 3)
        alpha_SNR : float
            Noise mixing parameter in [0, 1].
        sensor_white_noise_std : float
            Base noise standard deviation.
        seed : int
            Noise seed (used only for sensor noise).

        Returns
        -------
        y_clean : np.ndarray
            Noiseless sensor measurements, shape (n_sensors, n_times).
        y_noisy : np.ndarray
            Noisy sensor measurements, shape (n_sensors, n_times).
        noise : np.ndarray
            Added noise term (eta * eps), shape (n_sensors, n_times).
        noise_eta : float
            Noise scaling factor eta.
        """
        y_clean = self._project_sources_to_sensors(x=x, L=L)
        y_noisy, noise, noise_eta = self._add_noise(
            y_clean=y_clean,
            alpha_SNR=alpha_SNR,
            sensor_white_noise_std=sensor_white_noise_std,
            noise_seed=int(seed),
        )
        return y_clean, y_noisy, noise, noise_eta
    
    
# essential packages  
import numpy as np
import mne
from typing import Optional, Tuple
from mne.io.constants import FIFF


# =============================================================================
# Leadfield subset extraction (642 LH + 642 RH)
# =============================================================================
def extract_subset_leadfield_642x2(
    fwd_fif: str,
    n_per_hemi: int = 642,
    seed: int = 0,
    scale_to_nAm: bool = False,
    *,
    orientation_type: str = "fixed",     # "fixed" -> (M, Nsub), "free" -> (M, 3*Nsub)
    coil_name: Optional[str] = None,     # None keeps original channels; "mag"/"grad"/"eeg" picks by unit
) -> Tuple[np.ndarray, np.ndarray, "mne.Forward"]:
    """
    Extract a reproducible hemispheric subset of sources from an MNE forward solution.

    Parameters
    ----------
    fwd_fif : str
        Path to forward solution FIF file.
    n_per_hemi : int
        Number of sources to select per hemisphere (LH and RH). Default 642.
    seed : int
        Seed controlling the random subset selection. Default 0.
    scale_to_nAm : bool
        If True, multiply the returned leadfield by 1e-9 so it maps nAm -> sensor units
        (i.e., becomes sensor_unit / nAm). Default False.
        NOTE: Keep this consistent with your benchmark.
    orientation_type : {"fixed","free"}
        - "fixed": return L_sub shape (M, Nsub)
        - "free" : return L_sub shape (M, 3*Nsub) using MNE convention (Mx3N)
    coil_name : {None,"mag","grad","eeg"}
        Optional sensor picking by unit type:
          - "mag": FIFF_UNIT_T
          - "grad": FIFF_UNIT_T_M
          - "eeg": FIFF_UNIT_V
        If None (default), keep channels exactly as in the forward file (draft behavior).

    Returns
    -------
    L_sub : np.ndarray
        Subset leadfield.
        - fixed: (n_sensors, n_subset_sources)
        - free : (n_sensors, 3*n_subset_sources)
    subset_fwd_index : np.ndarray, shape (n_subset_sources,)
        Indices of selected sources in the forward solution's source ordering (LH then RH).
        These are *source indices* (not free-matrix column indices).
    fwd_out : mne.Forward
        Forward object after orientation conversion and optional channel picking.
    """
    rng = np.random.RandomState(int(seed))

    fwd = mne.read_forward_solution(fwd_fif, verbose="error")

    # -------------------------------------------------------------------------
    # (2) Channel picking ONLY if explicitly enabled (default: None -> no change)
    # -------------------------------------------------------------------------
    if coil_name is not None:
        coil_name = coil_name.lower().strip()
        if coil_name == "mag":
            keep = [ch["ch_name"] for ch in fwd["info"]["chs"] if ch.get("unit") == FIFF.FIFF_UNIT_T]
        elif coil_name == "grad":
            keep = [ch["ch_name"] for ch in fwd["info"]["chs"] if ch.get("unit") == FIFF.FIFF_UNIT_T_M]
        elif coil_name == "eeg":
            keep = [ch["ch_name"] for ch in fwd["info"]["chs"] if ch.get("unit") == FIFF.FIFF_UNIT_V]
        else:
            raise ValueError(f"Unknown coil_name: {coil_name} (use None/mag/grad/eeg)")
        fwd = fwd.pick_channels(keep)

    # -------------------------------------------------------------------------
    # (1) Orientation support (fixed or free). Free uses MNE's (M, 3N) convention
    # -------------------------------------------------------------------------
    orientation_type = orientation_type.lower().strip()
    if orientation_type == "fixed":
        fwd_out = mne.convert_forward_solution(fwd, force_fixed=True, surf_ori=True, verbose="error")
        L_full = fwd_out["sol"]["data"].astype(float)  # (M, Nfull)
    elif orientation_type == "free":
        fwd_out = mne.convert_forward_solution(fwd, force_fixed=False, surf_ori=True, verbose="error")
        L_full = fwd_out["sol"]["data"].astype(float)  # (M, 3*Nfull)
    else:
        raise ValueError("orientation_type must be 'fixed' or 'free'")

    # Hemisphere bookkeeping uses source counts (works for both orientations)
    src = fwd_out["src"]
    n_lh = int(src[0]["nuse"])
    n_rh = int(src[1]["nuse"])

    k_lh = min(int(n_per_hemi), n_lh)
    k_rh = min(int(n_per_hemi), n_rh)

    lh_sel = rng.choice(n_lh, size=k_lh, replace=False)
    rh_sel = rng.choice(n_rh, size=k_rh, replace=False)

    # Source indices in forward ordering: [LH..., RH...]
    subset_fwd_index = np.sort(np.concatenate([lh_sel, n_lh + rh_sel]).astype(int))

    # Extract subset columns
    if orientation_type == "fixed":
        L_sub = L_full[:, subset_fwd_index]  # (M, Nsub)
    else:
        # Map source indices to column triplets in the Mx3N matrix: cols = 3*m + {0,1,2}
        cols = (3 * subset_fwd_index[:, None] + np.arange(3)[None, :]).reshape(-1)
        L_sub = L_full[:, cols]  # (M, 3*Nsub)

    # Optional scaling (keep consistent with your benchmark!)
    if scale_to_nAm:
        L_sub = L_sub * 1e-9

    return L_sub, subset_fwd_index, fwd_out

#Helper function for visualisation of source and sensor signals

#essential packages
import logging
from typing import Optional, Sequence, Tuple

import numpy as np
import matplotlib.pyplot as plt


# ----------------------------
# Time axis helper (ERP config)
# ----------------------------
def get_times_from_erp_config(ERP_config: dict) -> np.ndarray:
    """Recreate the time vector used internally by SourceSimulator."""
    tmin = ERP_config["tmin"]
    tmax = ERP_config["tmax"]
    sfreq = ERP_config["sfreq"]
    return np.arange(tmin, tmax, 1.0 / sfreq)


# ------------------------------------------
# Leadfield helper: Mx3N -> (M, N, 3) view
# ------------------------------------------
def reshape_leadfield_Mx3N_to_MxNx3(L_Mx3N: np.ndarray) -> np.ndarray:
    """
    Convert an MNE free-orientation leadfield stored as (M, 3N) into (M, N, 3).

    Assumption (MNE convention):
      columns are grouped per source: [x1,y1,z1, x2,y2,z2, ..., xN,yN,zN]
    """
    if L_Mx3N.ndim != 2:
        raise ValueError(f"Expected 2D L of shape (M, 3N). Got {L_Mx3N.shape}")
    M, threeN = L_Mx3N.shape
    if threeN % 3 != 0:
        raise ValueError(f"Second dim must be divisible by 3 for free orientation. Got {threeN}")
    N = threeN // 3
    return L_Mx3N.reshape(M, N, 3)


# ---------------------------------------------------
# End-to-end simulation for one free-orientation trial
# ---------------------------------------------------
def simulate_one_trial_free(
    *,
    src_sim,
    sen_sim,
    L_free_Mx3N: np.ndarray,
    nnz: int,
    alpha_SNR: float,
    seed_trial: int,
    seed_noise: Optional[int] = None,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, float]:
    """
    Simulate a single trial in FREE orientation.

    Parameters
    ----------
    src_sim : SourceSimulator
    sen_sim : SensorSimulator
    L_free_Mx3N : np.ndarray
        Free leadfield in MNE flattened convention (M, 3N).
    nnz : int
        Number of active sources.
    alpha_SNR : float
        Noise mixing parameter in [0, 1].
    seed_trial : int
        Seed passed to source simulator to select active sources + per-source waveforms.
    seed_noise : int, optional
        Seed for sensor noise. If None, uses seed_trial (common convenience).

    Returns
    -------
    x : np.ndarray
        Source time courses, shape (N, 3, T)
    active_indices : np.ndarray
        Active source indices, shape (nnz,)
    y_clean : np.ndarray
        Clean sensor data, shape (M, T)
    y_noisy : np.ndarray
        Noisy sensor data, shape (M, T)
    noise_eta : float
        Noise scaling factor eta
    """
    if seed_noise is None:
        seed_noise = seed_trial

    # Reshape leadfield to (M, N, 3) for the sensor simulator’s free projection
    L_MxNx3 = reshape_leadfield_Mx3N_to_MxNx3(L_free_Mx3N)
    M, N, _ = L_MxNx3.shape

    # Source simulation in free orientation: x (N, 3, T)
    x, active_indices = src_sim.simulate(
        orientation_type="free",
        n_sources=N,
        nnz=nnz,
        seed=int(seed_trial),
    )

    # Sensor simulation: uses free projection internally when L is 3D and x is 3D
    y_clean, y_noisy, noise, noise_eta = sen_sim.simulate(
        x=x,
        L=L_MxNx3,
        alpha_SNR=float(alpha_SNR),
        sensor_white_noise_std=1.0,        # keep consistent with the benchmark setting
        seed=int(seed_noise),
    )

    return x, active_indices, y_clean, y_noisy, float(noise_eta)


# ------------------------
# Plotting: source signals
# ------------------------
def plot_sources_free(
    x: np.ndarray,
    active_indices: np.ndarray,
    times: np.ndarray,
    *,
    max_sources: int = 5,
    title: str = "Free-orientation sources (3 components)",
) -> None:
    """
    Plot up to max_sources active sources:
      - 3 component time series
      - magnitude ||x|| over time
    """
    if x.ndim != 3 or x.shape[1] != 3:
        raise ValueError(f"Expected x shape (N, 3, T). Got {x.shape}")

    picks = active_indices[:max_sources]
    n_plot = len(picks)

    fig, axes = plt.subplots(n_plot, 1, figsize=(10, 2.2 * n_plot), sharex=True)
    if n_plot == 1:
        axes = [axes]

    for ax, src_idx in zip(axes, picks):
        s = x[src_idx, :, :]  # (3, T)
        mag = np.linalg.norm(s, axis=0)

        ax.plot(times, s[0], label=f"src {src_idx} - x")
        ax.plot(times, s[1], label=f"src {src_idx} - y")
        ax.plot(times, s[2], label=f"src {src_idx} - z")
        ax.plot(times, mag, label=f"src {src_idx} - ||·||", linewidth=2)

        ax.axvline(0.0, linestyle="--", linewidth=1)  # stim_onset often 0.0 in your config
        ax.set_ylabel("nAm")
        ax.legend(loc="upper right", fontsize=8)

    axes[-1].set_xlabel("Time (s)")
    fig.suptitle(title)
    fig.tight_layout()
    plt.show()


# ------------------------
# Plotting: sensor signals
# ------------------------
def plot_sensors(
    y_clean: np.ndarray,
    y_noisy: np.ndarray,
    times: np.ndarray,
    *,
    picks: Optional[Sequence[int]] = None,
    max_sensors: int = 10,
    title: str = "Sensor signals (clean vs noisy)",
) -> None:
    """
    Plot selected sensor channels (clean and noisy).
    """
    M, T = y_clean.shape
    if y_noisy.shape != (M, T):
        raise ValueError("y_clean and y_noisy must have same shape")

    if picks is None:
        picks = list(range(min(M, max_sensors)))
    else:
        picks = list(picks)[:max_sensors]

    fig, ax = plt.subplots(1, 1, figsize=(10, 4))
    for ch in picks:
        ax.plot(times, y_clean[ch], alpha=0.8, label=f"ch {ch} clean")
        ax.plot(times, y_noisy[ch], alpha=0.5, linestyle="--", label=f"ch {ch} noisy")

    ax.axvline(0.0, linestyle="--", linewidth=1)
    ax.set_xlabel("Time (s)")
    ax.set_ylabel("Sensor units (depends on L)")
    ax.set_title(title)
    ax.legend(fontsize=7, ncol=2)
    fig.tight_layout()
    plt.show()


# ==========================
# Example usage
# ==========================
def demo_free_orientation_pipeline(
    *,
    FWD_FIF: str,
    extract_subset_leadfield_642x2,
    SourceSimulator,
    SensorSimulator,
    nnz: int = 10,
    alpha_SNR: float = 0.5,
    seed_base: int = 43,
    coil_name: Optional[str] = None,   # None preserves “no picking”
) -> None:
    """
    End-to-end sanity demo:
      - extract free leadfield subset as (M, 3Nsub)
      - simulate free sources
      - project + add noise
      - plot source and sensor signals
    """
    # 1) Leadfield subset in FREE orientation, flattened Mx3N
    L_free, subset_idx, fwd_out = extract_subset_leadfield_642x2(
        fwd_fif=FWD_FIF,
        n_per_hemi=642,
        seed=0,
        scale_to_nAm=False,          # keep consistent with your benchmark
        orientation_type="free",
        coil_name=coil_name,         # None by default => no picking
    )
    M, threeN = L_free.shape
    N = threeN // 3
    print(f"Leadfield subset (free): L shape = {L_free.shape} => M={M}, N={N}")
    print(f"Subset sources: {subset_idx.shape} (expect ~1284)")

    # 2) Init simulators
    src_sim = SourceSimulator(logger=logging.getLogger("source_sim"))
    sen_sim = SensorSimulator(logger=logging.getLogger("sensor_sim"))

    # 3) Simulate one trial (free)
    x, active, y_clean, y_noisy, eta = simulate_one_trial_free(
        src_sim=src_sim,
        sen_sim=sen_sim,
        L_free_Mx3N=L_free,
        nnz=int(nnz),
        alpha_SNR=float(alpha_SNR),
        seed_trial=int(seed_base),
        seed_noise=int(seed_base),   # keep aligned unless you want separate seeds
    )
    print(f"x: {x.shape} (N,3,T), active: {active.shape}, y_clean: {y_clean.shape}, eta={eta:.4g}")

    # 4) Plot
    times = get_times_from_erp_config(src_sim.ERP_config)
    plot_sources_free(x, active, times, max_sources=5)
    plot_sensors(y_clean, y_noisy, times, max_sensors=8)
    
    

