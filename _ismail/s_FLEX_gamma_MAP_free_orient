def compute_B(X, sigma, threshold_factor=3.0):
    """
    For a sparse basis field expansion we are using radial basis functions;
    spherical Gaussian basis on R^3 (see formula (6) in [1]).
    B[i,j] = (2πσ^2)^(-3/2) * exp(-||X[i]-X[j]||^2 / (2σ^2)),
    truncated to radius r = threshold_factor * sigma for sparsity.

    [1] Haufe et al., NIPS 2008.
    """
    X = np.asarray(X, float)
    N, D = X.shape                     # D should be 3 (x,y,z per location)
    assert D == 3, "X must have shape (N,3) with 3D coordinates."

    dist2 = squareform(pdist(X, 'sqeuclidean'))   # pairwise squared Euclidean distances (N×N)
    r2 = (threshold_factor * sigma) ** 2          # squared cutoff radius
    mask = dist2 <= r2                            # keep only neighbors within r
    rows, cols = np.nonzero(mask)                 # COO indices for kept pairs

    pref = (2.0 * np.pi * sigma**2) ** (-1.5)     # (2πσ²)^(-3/2) — 3D normalization factor
    weights = pref * np.exp(-dist2[rows, cols] / (2.0 * sigma**2))  # Gaussian weights

    B = coo_matrix((weights, (rows, cols)), shape=(N, N))  # build sparse matrix from triplets
    B = (B + B.T) * 0.5                                 # symmetrize without doubling off-diagonals
    return B.tocsr()                                     # CSR for fast algebra 

def sflex_gamma_map(L, y, X, sigma, noise_var, n_orient=1, max_iter=1000, tol=1e-15,
                    update_mode=2, init_gamma=None, verbose=True, logger=None,
                    threshold_factor=3.0):
    """
    Unified s-FLEX + γ-MAP implementation for both fixed and free orientation cases.
    
    Parameters
    ----------
    L : ndarray
        Lead field matrix.
    y : ndarray
        Sensor measurements.
    X : ndarray
        Source coordinates (N × 3).
    sigma : float
        Gaussian basis width parameter.
    noise_var : float
        Noise variance.
    n_orient : int
        Number of orientations (1 for fixed, 3 for free).
    max_iter : int
        Maximum number of iterations.
    tol : float
        Convergence tolerance.
    update_mode : int
        Gamma update mode.
    init_gamma : ndarray or None
        Initial gamma values.
    verbose : bool
        Whether to print progress.
    logger : object
        Logger object for progress reporting.
    threshold_factor : float
        Threshold factor for basis sparsity.
        
    Returns
    -------
    x_hat : ndarray
        Estimated source activity.
    active_indices : ndarray
        Indices of active sources.
    posterior_cov : ndarray
        Posterior covariance of active sources.
    """
    # Compute basis matrix
    B = compute_B(X, sigma, threshold_factor)
    N = X.shape[0]
    n_sources_basis = B.shape[1]  # Should be N
    
    # Handle orientation type
    if n_orient == 1:
        # Fixed-orientation case
        assert L.shape[1] == N, f"L has {L.shape[1]} cols, expected N={N} for fixed-orientation."
        G = L @ B  # (M × N)
        group_size = 1
    elif n_orient == 3:
        # Free-orientation case - EFFICIENT IMPLEMENTATION
        assert L.shape[1] == 3 * N, f"L has {L.shape[1]} cols, expected 3N={3*N} for free-orientation."
        
        # --- OLD, INEFFICIENT WAY ---
        # I3 = identity(3, format='csr')
        # B_big = kron(I3, B, format='csr')  # (3N, 3N) block-diag(B,B,B)
        # G = L @ B_big  # (M, 3N)
        
        # --- NEW, EFFICIENT WAY ---
        # L is shape (M, 3N). We can think of it as 3 blocks: L = [L_x, L_y, L_z], each (M, N)
        # The operation L @ (B ⊗ I_3) is equivalent to [L_x @ B, L_y @ B, L_z @ B]
        G_blocks = []
        for orient in range(3):
            # Extract the lead field block for this orientation
            L_block = L[:, orient * n_sources_basis : (orient+1) * n_sources_basis]
            # Apply the spatial basis to this component
            G_block = L_block @ B
            G_blocks.append(G_block)
        # Concatenate the results to form the final pseudo-lead field
        G = np.hstack(G_blocks)  # Shape: (M, 3N)
        
        group_size = 3
    else:
        raise ValueError("n_orient must be 1 (fixed) or 3 (free).")
    
    # Run gamma-MAP on G
    c_hat, active_indices, posterior_cov = gamma_map(
        L=G, y=y, noise_var=noise_var, n_orient=group_size,
        max_iter=max_iter, tol=tol, update_mode=update_mode,
        init_gamma=init_gamma, verbose=verbose, logger=logger
    )

    # Reconstruct sources
    if n_orient == 1:
        # Fixed-orientation
        x_hat = B @ c_hat  # (N, T)
        # Posterior covariance in source space
        posterior_cov_source = B[:, active_indices] @ posterior_cov @ B[:, active_indices].T
    else:
        # Free-orientation
        # For source reconstruction, we can use efficient block-wise approach
        x_hat_blocks = []
        for orient in range(3):
            # Extract coefficients for this orientation
            c_block = c_hat[orient * n_sources_basis : (orient+1) * n_sources_basis, :]
            # Apply basis matrix
            x_block = B @ c_block
            x_hat_blocks.append(x_block)
        # Stack along orientation dimension
        x_hat = np.stack(x_hat_blocks, axis=1)  # Shape: (N, 3, T)
        
        # For posterior covariance, we still need the Kronecker product for accuracy
        I3 = identity(3, format='csr')
        B_big = kron(I3, B, format='csr')
        posterior_cov_source = B_big[:, active_indices] @ posterior_cov @ B_big[:, active_indices].T
    
    return x_hat, active_indices, posterior_cov_source
